{
  "server": {
    "address": ":8080",
    "grpc_address": ":9090",
    "tls_cert_file": "configs/certs/dev.crt",
    "tls_key_file": "configs/certs/dev.key"
  },
  "database": {
    "dsn": "postgres://user:password@localhost:5432/gophkeeper?sslmode=disable"
  },
  "auth": {
    "jwt_secret": "dev-jwt-secret",
    "token_duration": 86400000000000
  },
  "crypto": {
    "master_key": "dev-master-key-32-bytes-long-0000"
  },
  "blob": {
    "provider": "local",
    "path": "data/blob"
  },
  "upload": {
    "max_file_size": 10485760,
    "max_chunk_size": 1048576,
    "max_total_size": 52428800
  }
}
